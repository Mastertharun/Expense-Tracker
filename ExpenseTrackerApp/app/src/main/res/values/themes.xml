<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ExpenseTracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- These MUST be present — MaterialCardView requires them -->
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorSurfaceVariant">@color/bg_surface</item>
        <item name="colorOutlineVariant">@color/divider</item>
        <item name="colorOutline">@color/divider</item>
        <item name="colorSecondaryContainer">@color/bg_surface</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>
        <item name="colorPrimaryContainer">@color/primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <item name="colorTertiary">@color/accent</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!--        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>-->
    </style>

    <style name="Theme.ExpenseTracker.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
<!--        <item name="windowSplashScreenBackground">@color/bg_dark</item>-->
<!--        <item name="postSplashScreenTheme">@style/Theme.ExpenseTracker</item>-->
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>


    <style name="CardStyle" parent="">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">16dp</item>
    </style>
</resources>
